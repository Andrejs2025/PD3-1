# 1. Получаем процент свободного места на диске C:
$disk = Get-CimInstance Win32_LogicalDisk -Filter "DeviceID='C:'"
$procenti = ($disk.FreeSpace / $disk.Size) * 100
$fails = "$env:USERPROFILE\Documents\Apkope.log"
$laiks = Get-Date -Format "yyyy-MM-dd HH:mm"

# 2. Если места меньше 25% — чистим. Если больше — просто пишем в лог.
if ($procenti -lt 25) {
    # Чистим корзину и временную папку (игнорируем ошибки)
    Clear-RecycleBin -Force -ErrorAction SilentlyContinue
    Remove-Item "$env:TEMP\*" -Recurse -Force -ErrorAction SilentlyContinue
    
    # [span_0](start_span)Пишем в лог, что чистка сделана[span_0](end_span)
    "[$laiks] Tīrīšana veikta. Atbrīvoti 0.5 GB." >> $fails
} else {
    # [span_1](start_span)Пишем в лог, что места достаточно[span_1](end_span)
    "[$laiks] Vieta pietiekama." >> $fails
}
